<Window x:Class="NexioFinance.Views.AddTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:Nexio_Finance.Properties"
        Title="{x:Static properties:Resources.WinAddTransactionTitle}" Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen" Background="#F3F4F6" ResizeMode="NoResize">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="{x:Static properties:Resources.AddRecord}" FontSize="22" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

            <TextBlock Text="{x:Static properties:Resources.TransactionTypeLabel}" Foreground="#6B7280" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="TypeComboBox" Margin="0,0,0,15" Padding="5" SelectionChanged="TypeComboBox_SelectionChanged">
                <ComboBoxItem Content="{x:Static properties:Resources.TypeExpense}" IsSelected="True"/>
                <ComboBoxItem Content="{x:Static properties:Resources.TypeIncome}"/>
                <ComboBoxItem Content="{x:Static properties:Resources.TypeTransfer}"/>
            </ComboBox>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="{x:Static properties:Resources.DateLabel}" Foreground="#6B7280" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <DatePicker x:Name="TransactionDatePicker" Padding="5"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{x:Static properties:Resources.AmountLabel}" Foreground="#6B7280" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="AmountTextBox" Padding="5"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{x:Static properties:Resources.AccountFromLabel}" Foreground="#6B7280" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="AccountComboBox" Margin="0,0,0,15" Padding="5" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="AccountComboBox_SelectionChanged"/>

            <CheckBox x:Name="IsOwnTransferCheckBox" Content="{x:Static properties:Resources.OwnTransferCheck}" Foreground="#374151" FontWeight="SemiBold" Margin="0,0,0,15" Visibility="Collapsed" Click="IsOwnTransferCheckBox_Click"/>

            <StackPanel x:Name="TransferTargetPanel" Visibility="Collapsed" Margin="0,0,0,15">
                <TextBlock Text="{x:Static properties:Resources.AccountToLabel}" Foreground="#6B7280" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="TargetAccountComboBox" Padding="5" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="TargetAccountComboBox_SelectionChanged" Margin="0,0,0,15"/>

                <StackPanel x:Name="ExchangeRatePanel" Visibility="Collapsed">
                    <TextBlock x:Name="ExchangeRateLabel" Text="{x:Static properties:Resources.ExchangeRateShort}" Foreground="#6B7280" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="ExchangeRateTextBox" Padding="5"/>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="CategoryPanel">
                <TextBlock x:Name="CategoryLabel" Text="{x:Static properties:Resources.CategoryLabel}" Foreground="#6B7280" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CategoryComboBox" Margin="0,0,0,15" Padding="5" DisplayMemberPath="Name" SelectedValuePath="Id"/>
            </StackPanel>

            <TextBlock Text="{x:Static properties:Resources.DescriptionLabel}" Foreground="#6B7280" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionTextBox" Margin="0,0,0,25" Padding="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="{x:Static properties:Resources.BtnCancel}" Margin="0,0,10,0" Padding="10" Background="White" BorderBrush="#D1D5DB" Click="Cancel_Click"/>
                <Button Grid.Column="1" Content="{x:Static properties:Resources.BtnSaveTransaction}" Margin="10,0,0,0" Padding="10" Background="#3B82F6" Foreground="White" BorderThickness="0" Click="Save_Click"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>