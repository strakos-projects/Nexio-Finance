<UserControl x:Class="NexioFinance.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:properties="clr-namespace:Nexio_Finance.Properties"
             Background="#F3F4F6">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="30" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <Grid>
                <ComboBox x:Name="TargetCurrencyComboBox" HorizontalAlignment="Right" VerticalAlignment="Top" Width="80" 
                          SelectionChanged="TargetCurrencyComboBox_SelectionChanged" Padding="5" Background="Transparent" BorderThickness="0"
                          DisplayMemberPath="Code" SelectedValuePath="Code">
                </ComboBox>

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{x:Static properties:Resources.TotalNetWorth}" Foreground="#6B7280" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TotalNetWorthTextBlock" Text="0,00 CZK" Foreground="#111827" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Text="{x:Static properties:Resources.TotalNetWorthDesc}" Foreground="#9CA3AF" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.YourAccounts}" FontSize="20" FontWeight="SemiBold" Margin="5,0,0,15" Foreground="#374151"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">

            <ItemsControl x:Name="AccountsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10" Width="250" Height="120" Margin="10" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
                            </Border.Effect>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="#374151"/>
                                    <TextBlock Text="{Binding Currency}" FontSize="12" Foreground="#9CA3AF"/>
                                </StackPanel>
                                <TextBlock Text="{Binding BalanceFormatted}" FontSize="24" FontWeight="Bold" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </ScrollViewer>
    </Grid>
</UserControl>