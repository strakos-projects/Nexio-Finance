<UserControl x:Class="NexioFinance.Views.AnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:properties="clr-namespace:Nexio_Finance.Properties"
             Background="#F3F4F6">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="{x:Static properties:Resources.AnalysisMonth}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,5,0"/>
                <ComboBox x:Name="MonthComboBox" Width="100" Padding="5" Margin="0,0,20,0" SelectionChanged="Filter_SelectionChanged"/>

                <TextBlock Text="{x:Static properties:Resources.AnalysisYear}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,5,0"/>
                <ComboBox x:Name="YearComboBox" Width="100" Padding="5" Margin="0,0,20,0" SelectionChanged="Filter_SelectionChanged"/>

                <TextBlock Text="{x:Static properties:Resources.AnalysisCurrency}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,5,0"/>
                <ComboBox x:Name="CurrencyComboBox" Width="80" Padding="5" SelectionChanged="Filter_SelectionChanged" DisplayMemberPath="Code" SelectedValuePath="Code"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{x:Static properties:Resources.AnalysisIncome}" Foreground="#6B7280" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TotalIncomeText" Text="0,00" FontSize="24" FontWeight="Bold" Foreground="#10B981" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20" Margin="10,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{x:Static properties:Resources.AnalysisExpense}" Foreground="#6B7280" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TotalExpenseText" Text="0,00" FontSize="24" FontWeight="Bold" Foreground="#EF4444" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{x:Static properties:Resources.AnalysisSavings}" Foreground="#6B7280" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SavingsText" Text="0,00" FontSize="24" FontWeight="Bold" Foreground="#3B82F6" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{x:Static properties:Resources.AnalysisIncomeSource}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Canvas x:Name="IncomePieCanvas" Width="180" Height="180" HorizontalAlignment="Left"/>
                            <StackPanel x:Name="IncomeLegend" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{x:Static properties:Resources.AnalysisExpenseDest}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Canvas x:Name="ExpensePieCanvas" Width="180" Height="180" HorizontalAlignment="Left"/>
                            <StackPanel x:Name="ExpenseLegend" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20" MinHeight="300">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock x:Name="BarChartTitle" Text="{x:Static properties:Resources.AnalysisExpenseDetail}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BackButton" Content="{x:Static properties:Resources.AnalysisBackToMain}" Background="Transparent" Foreground="#3B82F6" FontWeight="SemiBold" BorderThickness="0" Margin="20,0,0,0" Visibility="Collapsed" Click="BackButton_Click"/>
                    </StackPanel>

                    <Canvas x:Name="ExpenseBarCanvas" Grid.Row="1" Margin="10,30,10,10"/>
                </Grid>
            </Border>

            <Border Grid.Row="4" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,10" MinHeight="250">
                <StackPanel>
                    <TextBlock Text="{x:Static properties:Resources.AnalysisIncomeTrend}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <Canvas x:Name="IncomeTrendCanvas" Height="180" HorizontalAlignment="Left"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>