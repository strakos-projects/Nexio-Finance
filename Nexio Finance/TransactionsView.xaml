<UserControl x:Class="NexioFinance.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:properties="clr-namespace:Nexio_Finance.Properties"
             Background="#F3F4F6">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="{x:Static properties:Resources.SearchText}" Foreground="#6B7280" FontSize="12" Margin="0,0,0,2" FontWeight="SemiBold"/>
                    <TextBox x:Name="SearchTextBox" Width="130" Padding="5" TextChanged="SearchTextBox_TextChanged"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="{x:Static properties:Resources.FilterYear}" Foreground="#6B7280" FontSize="12" Margin="0,0,0,2" FontWeight="SemiBold"/>
                    <ComboBox x:Name="YearFilter" Width="80" Padding="5" SelectionChanged="Filter_Changed"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="{x:Static properties:Resources.FilterMonth}" Foreground="#6B7280" FontSize="12" Margin="0,0,0,2" FontWeight="SemiBold"/>
                    <ComboBox x:Name="MonthFilter" Width="70" Padding="5" SelectionChanged="Filter_Changed"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="{x:Static properties:Resources.FilterAccount}" Foreground="#6B7280" FontSize="12" Margin="0,0,0,2" FontWeight="SemiBold"/>
                    <ComboBox x:Name="AccountFilter" Width="120" Padding="5" SelectionChanged="Filter_Changed"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="{x:Static properties:Resources.FilterCategory}" Foreground="#6B7280" FontSize="12" Margin="0,0,0,2" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CategoryFilter" Width="130" Padding="5" SelectionChanged="Filter_Changed"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="{x:Static properties:Resources.FilterSubcategory}" Foreground="#6B7280" FontSize="12" Margin="0,0,0,2" FontWeight="SemiBold"/>
                    <ComboBox x:Name="SubcategoryFilter" Width="130" Padding="5" SelectionChanged="Filter_Changed"/>
                </StackPanel>

                <Button Content="{x:Static properties:Resources.ClearFilters}" Background="Transparent" Foreground="#EF4444" FontWeight="SemiBold" BorderThickness="0" Margin="0,15,0,0" Click="ClearFilters_Click" VerticalAlignment="Center"/>
            </WrapPanel>

            <Button Click="AddTransaction_Click" Grid.Column="1" VerticalAlignment="Top" Background="#3B82F6" Foreground="White" Padding="15,8" BorderThickness="0">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontWeight="Bold" Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static properties:Resources.AddTransaction}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </Grid>
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>

            <DataGrid x:Name="TransactionsGrid" MouseDoubleClick="TransactionsGrid_MouseDoubleClick"
                      AutoGenerateColumns="False" HeadersVisibility="Column" 
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E7EB"
                      BorderThickness="0" Background="Transparent" RowHeight="45"
                      IsReadOnly="True">

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{x:Static properties:Resources.ContextEdit}" Click="EditContext_Click"/>
                        <Separator/>
                        <MenuItem Header="{x:Static properties:Resources.ContextDelete}" Click="DeleteContext_Click" Foreground="#EF4444" FontWeight="SemiBold"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColDate}" Binding="{Binding Date, StringFormat=dd. MM. yyyy}" Width="100"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColAccount}" Binding="{Binding Account}" Width="150"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColCategory}" Binding="{Binding Category}" Width="150"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColSubcategory}" Binding="{Binding Subcategory}" Width="150"/>

                    <DataGridTemplateColumn Header="{x:Static properties:Resources.ColAmount}" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Amount}" Foreground="{Binding AmountColor}" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="{x:Static properties:Resources.ColDescription}" Binding="{Binding Description}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>