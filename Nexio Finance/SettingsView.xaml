<UserControl x:Class="NexioFinance.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:properties="clr-namespace:Nexio_Finance.Properties"
             Background="#F3F4F6">
    <Grid Margin="20">
        <TabControl Background="Transparent" BorderThickness="0">

            <TabItem Header="{x:Static properties:Resources.TabAccounts}" FontSize="16" FontWeight="SemiBold">
                <Grid Background="White" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="AccountsListBox" Grid.Column="0" Margin="10" BorderBrush="#E5E7EB" 
                             DisplayMemberPath="Name" SelectionChanged="AccountsListBox_SelectionChanged"/>

                    <StackPanel Grid.Column="1" Margin="20">
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="{x:Static properties:Resources.AccountDetail}" FontSize="18" FontWeight="SemiBold"/>
                            <Button Content="{x:Static properties:Resources.BtnNewAccount}" HorizontalAlignment="Right" Background="Transparent" Foreground="#3B82F6" BorderThickness="0" Click="NewAccount_Click"/>
                        </Grid>

                        <TextBlock Text="{x:Static properties:Resources.LblAccountName}"/>
                        <TextBox x:Name="AccountNameTextBox" Margin="0,5,0,15" Padding="5"/>

                        <TextBlock Text="{x:Static properties:Resources.LblCurrency}"/>
                        <ComboBox x:Name="AccountCurrencyComboBox" Margin="0,5,0,15" Padding="5" DisplayMemberPath="Code" SelectedValuePath="Code"/>

                        <TextBlock Text="{x:Static properties:Resources.LblInitialBalance}"/>
                        <TextBox x:Name="AccountBalanceTextBox" Margin="0,5,0,25" Padding="5"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="{x:Static properties:Resources.BtnDeleteAccount}" Background="#EF4444" Foreground="White" Padding="10" Margin="0,0,5,0" BorderThickness="0" Click="DeleteAccount_Click"/>
                            <Button Grid.Column="1" Content="{x:Static properties:Resources.BtnSaveAccount}" Background="#10B981" Foreground="White" Padding="10" Margin="5,0,0,0" BorderThickness="0" Click="SaveAccount_Click"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="{x:Static properties:Resources.TabCategories}" FontSize="16" FontWeight="SemiBold">
                <Grid Background="White" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <TreeView x:Name="CategoriesTreeView" Grid.Column="0" Margin="10" BorderBrush="#E5E7EB" SelectedItemChanged="CategoriesTreeView_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding SubCategories}">
                                <TextBlock Text="{Binding Name}" />
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <StackPanel x:Name="CategoryDetailPanel" Grid.Column="1" Margin="20" VerticalAlignment="Top">
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="{x:Static properties:Resources.CategoryDetail}" FontSize="18" FontWeight="SemiBold"/>
                            <Button Content="{x:Static properties:Resources.BtnNewCategory}" HorizontalAlignment="Right" Background="Transparent" Foreground="#3B82F6" BorderThickness="0" Click="NewCategory_Click"/>
                        </Grid>

                        <TextBlock Text="{x:Static properties:Resources.LblCategoryName}"/>
                        <TextBox x:Name="CategoryNameTextBox" Margin="0,5,0,15" Padding="5"/>

                        <TextBlock Text="{x:Static properties:Resources.LblBehaviorType}"/>
                        <ComboBox x:Name="CategoryTypeComboBox" Margin="0,5,0,15" Padding="5">
                            <ComboBoxItem Content="{x:Static properties:Resources.TypeExpense}"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.TypeIncome}"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.TypeTransfer}"/>
                        </ComboBox>

                        <TextBlock Text="{x:Static properties:Resources.LblParentCategory}"/>
                        <ComboBox x:Name="ParentCategoryComboBox" Margin="0,5,0,25" Padding="5" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="{x:Static properties:Resources.BtnDeleteCategory}" Background="#EF4444" Foreground="White" Padding="10" Margin="0,0,5,0" BorderThickness="0" Click="DeleteCategory_Click"/>
                            <Button Grid.Column="1" Content="{x:Static properties:Resources.BtnSaveCategory}" Background="#10B981" Foreground="White" Padding="10" Margin="5,0,0,0" BorderThickness="0" Click="SaveCategory_Click"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="{x:Static properties:Resources.TabCurrencies}" FontSize="16" FontWeight="SemiBold">
                <Grid Background="White" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="CurrenciesListBox" Grid.Column="0" Margin="10" BorderBrush="#E5E7EB" 
                             DisplayMemberPath="Code" SelectionChanged="CurrenciesListBox_SelectionChanged"/>

                    <StackPanel Grid.Column="1" Margin="20">
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="{x:Static properties:Resources.CurrencyDetail}" FontSize="18" FontWeight="SemiBold"/>
                            <Button Content="{x:Static properties:Resources.BtnNewCurrency}" HorizontalAlignment="Right" Background="Transparent" Foreground="#3B82F6" BorderThickness="0" Click="NewCurrency_Click"/>
                        </Grid>

                        <TextBlock Text="{x:Static properties:Resources.LblCurrencyCode}"/>
                        <TextBox x:Name="CurrencyCodeTextBox" Margin="0,5,0,15" Padding="5"/>

                        <CheckBox x:Name="IsMainCurrencyCheckBox" Content="{x:Static properties:Resources.ChkMainCurrency}" 
                                  Margin="0,0,0,15" FontWeight="SemiBold" Click="IsMainCurrencyCheckBox_Click"/>

                        <TextBlock x:Name="CurrencyRateLabel" Text="{x:Static properties:Resources.LblExchangeRate}"/>
                        <TextBox x:Name="CurrencyRateTextBox" Margin="0,5,0,25" Padding="5"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="{x:Static properties:Resources.BtnDeleteCurrency}" Background="#EF4444" Foreground="White" Padding="10" Margin="0,0,5,0" BorderThickness="0" Click="DeleteCurrency_Click"/>
                            <Button Grid.Column="1" Content="{x:Static properties:Resources.BtnSaveCurrency}" Background="#10B981" Foreground="White" Padding="10" Margin="5,0,0,0" BorderThickness="0" Click="SaveCurrency_Click"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="{x:Static properties:Resources.TabBackup}" FontSize="16" FontWeight="SemiBold">
                <Grid Background="White" Margin="0,15,0,0">
                    <StackPanel Margin="30" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <TextBlock Text="{x:Static properties:Resources.BackupTitle}" FontSize="22" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,10"/>
                        <TextBlock Text="{x:Static properties:Resources.BackupDesc}" Foreground="#6B7280" TextWrapping="Wrap" Width="500" Margin="0,0,0,30" HorizontalAlignment="Left"/>

                        <Button Content="{x:Static properties:Resources.BtnExportJson}" Background="#3B82F6" Foreground="White" Padding="15,12" Margin="0,0,0,15" BorderThickness="0" FontWeight="SemiBold" Width="300" HorizontalAlignment="Left" Click="ExportJson_Click"/>
                        <Button Content="{x:Static properties:Resources.BtnImportJson}" Background="#EF4444" Foreground="White" Padding="15,12" Margin="0,0,0,15" BorderThickness="0" FontWeight="SemiBold" Width="300" HorizontalAlignment="Left" Click="ImportJson_Click"/>

                        <Border Height="1" Background="#E5E7EB" Width="300" HorizontalAlignment="Left" Margin="0,10,0,25"/>

                        <Button Content="{x:Static properties:Resources.BtnExportCsv}" Background="#10B981" Foreground="White" Padding="15,12" Margin="0,0,0,15" BorderThickness="0" FontWeight="SemiBold" Width="300" HorizontalAlignment="Left" Click="ExportCsv_Click"/>
                        <Button Content="{x:Static properties:Resources.BtnImportCsv}" Background="#10B981" Foreground="White" Padding="15,12" Margin="0,0,0,15" BorderThickness="0" FontWeight="SemiBold" Width="300" HorizontalAlignment="Left" Click="ImportCsv_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>